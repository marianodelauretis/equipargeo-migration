---
const herramientas = [
  { nombre: 'Conversor POSGAR07', desc: 'Lat/Lon DMS → Gauss-Krüger', href: 'https://equipargeo-tools.pages.dev/posgar07/', icon: '🧭' },
  { nombre: 'Consulta de faja', desc: 'Detector de faja GNSS', href: 'https://equipargeo-tools.pages.dev/faja/', icon: '📍' },
  { nombre: 'Puntos intermedios', desc: 'Generador con DXF/CSV export', href: 'https://equipargeo-tools.pages.dev/puntos-intermedios/', icon: '📐' },
  { nombre: 'CSV → DXF', desc: 'Conversor con preview canvas', href: 'https://equipargeo-tools.pages.dev/conversor-dxf/', icon: '🗂️' },
];
---
<section class="section-eg bg-eg-bg-soft">
  <div class="container-eg">
    <div class="text-center mb-10 max-w-2xl mx-auto">
      <span class="badge-eg mb-3">Gratis · Sin instalación</span>
      <h2 class="mb-3">Herramientas para tu trabajo de campo y gabinete</h2>
      <p class="text-eg-text-muted text-lg leading-relaxed">
        Cargan en menos de medio segundo, funcionan offline y se pueden instalar en el celular como app.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {herramientas.map((h) => (
        <a href={h.href} target="_blank" rel="noopener noreferrer" class="card-eg card-eg-hover flex flex-col gap-2 no-underline hover:no-underline">
          <div class="text-3xl mb-1">{h.icon}</div>
          <h3 class="text-eg-azul text-base font-bold">{h.nombre}</h3>
          <p class="text-eg-text-muted text-sm leading-snug">{h.desc}</p>
          <span class="text-eg-coral font-bold text-sm mt-auto">Abrir ↗</span>
        </a>
      ))}
    </div>

    <div class="text-center">
      <a href="https://equipargeo-tools.pages.dev/" target="_blank" rel="noopener noreferrer" class="btn-eg-secondary">
        Ver todas las herramientas ↗
      </a>
    </div>
  </div>
</section>
