---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
};

const navLinks = [
  { href: '/cursos/', label: 'Cursos' },
  { href: '/noticias/', label: 'Noticias' },
  { href: '/asesoria/', label: 'Asesoría' },
  { href: 'https://app.equipargeo.com/', label: 'Herramientas', external: true },
  { href: '/sobre/', label: 'Sobre' },
  { href: '/contacto/', label: 'Contacto' },
];
---
<header class="sticky top-0 z-40 bg-gradient-to-b from-eg-azul-dark to-eg-azul text-white shadow-md">
  <div class="container-eg-wide flex items-center justify-between gap-4 py-3.5">
    <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-wide no-underline text-white hover:no-underline hover:opacity-90">
      <span class="w-2.5 h-2.5 rounded-full bg-eg-coral inline-block"></span>
      EQUIPAR
    </a>

    <nav class="hidden md:flex items-center gap-1 text-sm" aria-label="Principal">
      {navLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class:list={[
            'px-3 py-2 rounded-md transition-colors no-underline hover:no-underline',
            isActive(link.href) ? 'bg-white/15 text-white' : 'text-white/85 hover:bg-white/10 hover:text-white',
          ]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}{link.external && ' ↗'}
        </a>
      ))}
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 text-white"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="md:hidden hidden bg-eg-azul border-t border-white/10"
    aria-label="Menú móvil"
  >
    <div class="container-eg-wide py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class:list={[
            'px-3 py-2.5 rounded-md text-white/85 hover:bg-white/10 hover:text-white no-underline hover:no-underline',
            isActive(link.href) && 'bg-white/15 text-white',
          ]}
        >
          {link.label}{link.external && ' ↗'}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
