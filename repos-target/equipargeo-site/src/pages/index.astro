---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ProgramaCard from '@components/ProgramaCard.astro';
import HerramientasFeatured from '@components/HerramientasFeatured.astro';
import Newsletter from '@components/Newsletter.astro';
import NoticiaCard from '@components/NoticiaCard.astro';
import { getCollection } from 'astro:content';

// Últimas 3 noticias publicadas (filtro explícito por publicada === true)
const todasNoticias = await getCollection('noticias');
const noticiasRecientes = todasNoticias
  .filter((n) => n.data.publicada === true)
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

const features = [
  { titulo: 'Instructores en actividad', desc: 'Quienes dictan los cursos firman mensuras, replanteos y vuelos en obra todos los meses. No es academia desconectada del campo.' },
  { titulo: 'Material descargable', desc: 'Bajás slides, cheat sheets de configuración, plantillas de cálculo y datasets de práctica. Te quedan en tu PC para consulta cuando estés trabajando.' },
  { titulo: 'Casos reales', desc: 'Trabajás con datasets reales: relevamientos GNSS en provincia de Buenos Aires, replanteos en obra civil, post-proceso de campañas con bases RAMSAC.' },
  { titulo: 'Acompañamiento técnico', desc: 'Soporte por WhatsApp durante el curso y 30 días después, mientras hacés tu primer trabajo aplicando lo que aprendiste.' },
];
---
<BaseLayout
  title="EQUIPAR — Cursos prácticos en GNSS, topografía y fotogrametría"
  description="Capacitación en GNSS, topografía y fotogrametría con instructores en actividad. Herramientas gratuitas, casos reales, material descargable."
>
  <Hero
    titulo="Cursos prácticos en GNSS, topografía y fotogrametría"
    subtitulo="Cursos GNSS, topografía y fotogrametría dictados por agrimensores y topógrafos en actividad. Material descargable, datasets reales y soporte por WhatsApp mientras aplicás lo que aprendiste."
    ctaPrimario={{ href: '/cursos/', label: 'Ver cursos y precios' }}
    ctaSecundario={{ href: '/asesoria/', label: 'Consultar por proyecto técnico' }}
  />

  <!-- Programas -->
  <section class="section-eg">
    <div class="container-eg">
      <div class="text-center mb-10 max-w-2xl mx-auto">
        <h2 class="mb-3">Tres programas, un mismo enfoque práctico</h2>
        <p class="text-eg-text-muted text-lg">
          Cada programa se divide en 3 módulos. Podés cursar el programa completo o módulos sueltos según lo que necesites profundizar.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <ProgramaCard
          titulo="GNSS"
          descripcion="Receptores GNSS, RTK, post-proceso. Desde fundamentos hasta resolución de ambigüedades en software profesional."
          modulos={3}
          modalidad="Online"
          href="/cursos/gnss/"
          destacado={true}
        />
        <ProgramaCard
          titulo="Topografía"
          descripcion="Estaciones totales, nivelación y replanteo. Operación, cálculo y vuelco a software CAD."
          modulos={3}
          modalidad="Online"
          href="/cursos/topografia/"
        />
        <ProgramaCard
          titulo="Fotogrametría"
          descripcion="Drones, planificación de vuelos, captura, procesamiento y productos finales."
          modulos={3}
          modalidad="Online"
          href="/cursos/fotogrametria/"
        />
      </div>
    </div>
  </section>

  <!-- Herramientas -->
  <HerramientasFeatured />

  <!-- Por qué EQUIPAR -->
  <section class="section-eg">
    <div class="container-eg">
      <div class="text-center mb-10 max-w-2xl mx-auto">
        <h2 class="mb-3">Por qué EQUIPAR</h2>
        <p class="text-eg-text-muted text-lg">
          Capacitación pensada para resolver problemas reales del trabajo de campo y gabinete.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((f) => (
          <div class="text-center">
            <h3 class="text-eg-azul text-lg mb-2">{f.titulo}</h3>
            <p class="text-eg-text-muted text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Últimas novedades -->
  {noticiasRecientes.length > 0 && (
    <section class="section-eg bg-eg-bg-soft">
      <div class="container-eg">
        <div class="flex flex-wrap items-end justify-between gap-4 mb-8">
          <div>
            <h2 class="mb-2">Últimas novedades</h2>
            <p class="text-eg-text-muted">Instrumental, software y normativa al día.</p>
          </div>
          <a href="/noticias/" class="btn-eg-ghost">Ver todas →</a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {noticiasRecientes.map((noticia) => (
            <NoticiaCard noticia={noticia} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Sobre EQUIPAR (preview) -->
  <section class="section-eg">
    <div class="container-eg max-w-3xl text-center">
      <h2 class="mb-4">Sobre EQUIPAR</h2>
      <p class="text-eg-text-muted text-lg leading-relaxed mb-6">
        EQUIPAR es un proyecto de capacitación, consultoría técnica y herramientas para agrimensura, topografía y fotogrametría en Argentina.
        Los cursos los dictan agrimensores y topógrafos matriculados en actividad, con trabajo cotidiano en estudios privados, obra civil y administración pública.
        Capacitamos sobre el instrumental que usamos todos los días: receptores GNSS RTK, estaciones totales, niveles y drones.
      </p>
      <a href="/sobre/" class="btn-eg-secondary">Conocer más</a>
    </div>
  </section>

  <!-- Newsletter -->
  <Newsletter />

  <!-- CTA cierre -->
  <section class="section-eg">
    <div class="container-eg">
      <div class="bg-gradient-to-br from-eg-azul-dark to-eg-azul text-white rounded-3xl p-8 md:p-12 text-center">
        <h2 class="text-white mb-3">Capacitación para estudios, municipios y empresas</h2>
        <p class="text-white/85 text-lg mb-6 max-w-2xl mx-auto">
          Si tenés 3 o más personas que necesitan formarse en un workflow específico — relevamiento GNSS, vuelos con drones, post-proceso, software CAD topográfico — armamos un curso ajustado a tu equipo, en tu oficina o por videollamada.
        </p>
        <a href="/contacto/" class="btn-eg-primary">Pedir propuesta para mi equipo</a>
      </div>
    </div>
  </section>
</BaseLayout>
