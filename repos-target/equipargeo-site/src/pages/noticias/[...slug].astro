---
import { getCollection } from 'astro:content';
import NoticiaLayout from '@layouts/NoticiaLayout.astro';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias', ({ data }) => data.publicada);
  return noticias.map((noticia) => ({
    params: { slug: noticia.slug },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { Content } = await noticia.render();
---
<NoticiaLayout noticia={noticia}>
  <Content />
</NoticiaLayout>
