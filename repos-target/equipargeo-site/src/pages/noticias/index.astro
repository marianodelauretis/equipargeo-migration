---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import NoticiaCard from '@components/NoticiaCard.astro';
import { getCollection } from 'astro:content';

const noticias = await getCollection('noticias', ({ data }) => data.publicada);
const noticiasOrdenadas = noticias.sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---
<BaseLayout
  title="Noticias — EQUIPAR"
  description="Novedades de instrumental GNSS, software de procesamiento, normativa catastral y casos prácticos. Actualizaciones para agrimensores, topógrafos e ingenieros."
>
  <Hero
    titulo="Novedades para agrimensores, topógrafos e ingenieros"
    subtitulo="Instrumental, software, normativa y casos prácticos. Lo nuevo que afecta tu trabajo de campo y gabinete."
    variante="compact"
  />

  <div class="container-eg py-8">
    <Breadcrumb items={[{ href: '/', label: 'Inicio' }, { label: 'Noticias', current: true }]} />

    {noticiasOrdenadas.length === 0 ? (
      <div class="card-eg text-center py-12">
        <h3 class="mb-3">Próximamente</h3>
        <p class="text-eg-text-muted">Estamos preparando las primeras notas. Suscribite a las novedades para enterarte cuando publiquemos.</p>
        <a href="/contacto/" class="btn-eg-secondary mt-4">Avisame cuando publiquen</a>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {noticiasOrdenadas.map((noticia) => (
          <NoticiaCard noticia={noticia} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
