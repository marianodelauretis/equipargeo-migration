---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

const whatsappNum = '5491155722266';
const whatsappLink = `https://wa.me/${whatsappNum}?text=${encodeURIComponent('Hola EQUIPAR, vengo de equipargeo.com y tengo una consulta')}`;
---
<BaseLayout
  title="Contacto — EQUIPAR"
  description="Contactá a EQUIPAR para cursos, asesoría técnica, capacitaciones in-company o consultas sobre las herramientas gratuitas."
>
  <Hero
    titulo="Hablemos"
    subtitulo="Sobre cursos, asesoría, equipamiento o cualquier consulta técnica. Te respondemos en 24-48 hs hábiles."
    variante="compact"
  />

  <div class="container-eg py-8">
    <Breadcrumb items={[{ href: '/', label: 'Inicio' }, { label: 'Contacto', current: true }]} />
  </div>

  <section class="section-eg">
    <div class="container-eg max-w-3xl">
      <div class="grid sm:grid-cols-2 gap-6 mb-8">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="card-eg card-eg-hover no-underline hover:no-underline">
          <div class="text-4xl mb-3">💬</div>
          <h3 class="text-eg-azul mb-2">WhatsApp</h3>
          <p class="text-eg-text-muted text-sm mb-4">Canal más rápido para consultas, cursos y asesoría puntual.</p>
          <span class="btn-eg-primary inline-block w-full">Abrir WhatsApp →</span>
        </a>

        <a href="/agenda/" class="card-eg card-eg-hover no-underline hover:no-underline">
          <div class="text-4xl mb-3">📅</div>
          <h3 class="text-eg-azul mb-2">Agendar curso</h3>
          <p class="text-eg-text-muted text-sm mb-4">Si ya sabés qué programa te interesa, completá el formulario.</p>
          <span class="btn-eg-secondary inline-block w-full">Ir a agenda →</span>
        </a>

        <a href="https://app.equipargeo.com/" target="_blank" rel="noopener noreferrer" class="card-eg card-eg-hover no-underline hover:no-underline">
          <div class="text-4xl mb-3">🛠️</div>
          <h3 class="text-eg-azul mb-2">Herramientas gratuitas</h3>
          <p class="text-eg-text-muted text-sm mb-4">No necesitás contactarnos para usarlas — son gratis.</p>
          <span class="btn-eg-ghost inline-block w-full">Ver herramientas ↗</span>
        </a>

        <a href="/asesoria/" class="card-eg card-eg-hover no-underline hover:no-underline">
          <div class="text-4xl mb-3">🎯</div>
          <h3 class="text-eg-azul mb-2">Asesoría técnica</h3>
          <p class="text-eg-text-muted text-sm mb-4">Para problemas puntuales, equipamiento o capacitación a medida.</p>
          <span class="btn-eg-ghost inline-block w-full">Ver servicios →</span>
        </a>
      </div>

      <div class="card-eg text-center bg-eg-bg-soft">
        <h3 class="mb-2">Horarios de atención</h3>
        <p class="text-eg-text-muted">
          Respondemos consultas por WhatsApp en horario laboral (lunes a viernes, 9:00 a 18:00 ART).<br>
          Fuera de horario, te respondemos al día siguiente hábil.
        </p>
        <!-- COMPLETAR: agregar horario real si difiere -->
      </div>
    </div>
  </section>
</BaseLayout>
