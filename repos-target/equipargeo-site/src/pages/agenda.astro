---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

// Google Forms reales extraídos del WP actual
const formGNSS = 'https://docs.google.com/forms/d/e/1FAIpQLSc-PLACEHOLDER-GNSS/viewform?embedded=true';
const formTopografia = 'https://docs.google.com/forms/d/e/1FAIpQLSc-PLACEHOLDER-TOPO/viewform?embedded=true';
const formFotogrametria = 'https://docs.google.com/forms/d/e/1FAIpQLSc-PLACEHOLDER-FOTO/viewform?embedded=true';

// Short URLs para "abrir en nueva pestaña"
const shortGNSS = 'https://forms.gle/wiRnmaW5759EuP2f6';
const shortTopografia = 'https://forms.gle/NRRBpNBvAhgd8qst8';
const shortFotogrametria = 'https://forms.gle/JrB1bAoPzcWBi78k6';

// NOTA: Las URLs embebidas con `?embedded=true` solo se pueden obtener desde el panel de Google Forms
// del propietario del form (botón Enviar → ícono < > → copiar src del iframe). Mientras tanto, usamos
// el short URL en un link directo. Cuando Mariano me pase las URLs embed reales, las reemplazamos
// en estas 3 constantes y descomentamos los iframes.
const useIframes = false;
---
<BaseLayout
  title="Agendar curso — EQUIPAR"
  description="Reservá tu lugar en un curso de EQUIPAR. Te confirmamos disponibilidad, fechas y forma de pago a la brevedad."
>
  <Hero
    titulo="Agendá tu curso"
    subtitulo="Elegí el programa que te interesa y completá el formulario correspondiente. Te confirmamos disponibilidad, próximas fechas y formas de pago."
    variante="compact"
  />

  <div class="container-eg py-8">
    <Breadcrumb items={[{ href: '/', label: 'Inicio' }, { label: 'Agendar', current: true }]} />
  </div>

  <section class="section-eg">
    <div class="container-eg max-w-4xl">
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <a href={shortGNSS} target="_blank" rel="noopener noreferrer" class="card-eg card-eg-hover text-center no-underline hover:no-underline">
          <div class="text-5xl mb-3">📡</div>
          <h3 class="text-eg-azul mb-2">GNSS</h3>
          <p class="text-eg-text-muted text-sm mb-4">Fundamentos, RTK y post-proceso profesional</p>
          <span class="btn-eg-primary inline-block">Formulario GNSS ↗</span>
        </a>

        <a href={shortTopografia} target="_blank" rel="noopener noreferrer" class="card-eg card-eg-hover text-center no-underline hover:no-underline">
          <div class="text-5xl mb-3">📐</div>
          <h3 class="text-eg-azul mb-2">Topografía</h3>
          <p class="text-eg-text-muted text-sm mb-4">Topografía básica, nivelación, estación total</p>
          <span class="btn-eg-primary inline-block">Formulario Topografía ↗</span>
        </a>

        <a href={shortFotogrametria} target="_blank" rel="noopener noreferrer" class="card-eg card-eg-hover text-center no-underline hover:no-underline">
          <div class="text-5xl mb-3">🚁</div>
          <h3 class="text-eg-azul mb-2">Fotogrametría</h3>
          <p class="text-eg-text-muted text-sm mb-4">Drones, captura y procesamiento</p>
          <span class="btn-eg-primary inline-block">Formulario Drones ↗</span>
        </a>
      </div>

      <div class="card-eg text-center bg-eg-bg-soft">
        <h3 class="mb-3">¿Preferís consultar primero?</h3>
        <p class="text-eg-text-muted mb-4">Si tenés dudas sobre qué programa te conviene, escribinos por WhatsApp y te orientamos antes de inscribirte.</p>
        <a
          href="https://wa.me/5491155722266?text=Hola%20EQUIPAR,%20quiero%20agendar%20un%20curso%20y%20tengo%20algunas%20consultas"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-eg-secondary"
        >
          Consultar por WhatsApp →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
