---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="Página no encontrada — EQUIPAR"
  description="La página que buscás no existe o fue movida."
  noindex={true}
>
  <section class="section-eg">
    <div class="container-eg max-w-2xl text-center">
      <div class="text-7xl md:text-8xl font-bold text-eg-coral mb-4">404</div>
      <h1 class="mb-4">Página no encontrada</h1>
      <p class="text-eg-text-muted text-lg mb-8">
        La página que buscás no existe o fue movida. Probablemente venís de un link viejo después de la migración del sitio.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mb-12">
        <a href="/" class="btn-eg-primary">Ir al inicio</a>
        <a href="/cursos/" class="btn-eg-secondary">Ver cursos</a>
        <a href="https://equipargeo-tools.pages.dev/" target="_blank" rel="noopener noreferrer" class="btn-eg-ghost">Herramientas ↗</a>
      </div>

      <div class="card-eg text-left">
        <h3 class="mb-3">Quizás buscabas:</h3>
        <ul class="space-y-2 text-eg-text-main">
          <li><a href="/cursos/" class="text-eg-coral font-bold">Programas y cursos</a> — GNSS, topografía, fotogrametría</li>
          <li><a href="https://equipargeo-tools.pages.dev/" target="_blank" rel="noopener noreferrer" class="text-eg-coral font-bold">Herramientas gratuitas ↗</a> — POSGAR07, faja, puntos intermedios, DXF</li>
          <li><a href="/noticias/" class="text-eg-coral font-bold">Notas técnicas</a> — instrumental, software, normativa</li>
          <li><a href="/asesoria/" class="text-eg-coral font-bold">Asesoría técnica</a> — consultoría y capacitación a medida</li>
          <li><a href="/contacto/" class="text-eg-coral font-bold">Contacto</a> — escribinos directamente</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
